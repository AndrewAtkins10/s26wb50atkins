extends layout

block content
  h1= title
  - let results = [{color: "Red", wheel_size: 20, brand: "Nimbus"}, {color: "Blue", wheel_size: 24, brand: "Club"}, {color: "Black", wheel_size: 19, brand: "Impact"}]
  div(class="container-fluid") 
    div(class="row")
      each item, index in results
        div(class="col-sm-2", onclick=`buy(${index})`) 
          p Brand: #{item.brand}
          p Color: #{item.color}
          p Wheel Size: #{item.wheel_size}

  script.
    function buy(index) {
      alert(`You purchased item ${index}`);
    } 