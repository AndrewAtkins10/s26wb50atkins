extends layout

block content
  h1= title
  - var image_names = ['uni1.jpg', 'uni2.jpg', 'uni3.jpg', 'uni4.jpg', 'uni5.jpg'] 
  - for(let i=0; i<3; i++) 
    - let random = Math.floor(Math.random()*5)
    img(src=`/images/${image_names[random]}`, alt=`${image_names[random]}`, height="300", width="300") 